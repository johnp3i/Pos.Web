@inherits LayoutComponentBase
@inject IState<KitchenState> KitchenState

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="kitchen-layout">
    <!-- Kitchen Header with Status -->
    <div class="kitchen-header">
        <MudPaper Elevation="3" Class="pa-3">
            <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudItem xs="3">
                    <MudText Typo="Typo.h4" Color="Color.Primary">
                        <MudIcon Icon="@Icons.Material.Filled.Restaurant" Size="Size.Large" Class="mr-2" />
                        Kitchen Display
                    </MudText>
                </MudItem>
                <MudItem xs="6" Class="text-center">
                    <MudChipSet T="string">
                        <MudChip T="string" Color="Color.Warning" Size="Size.Large">
                            Pending: @GetOrderCountByStatus(OrderStatus.Pending)
                        </MudChip>
                        <MudChip T="string" Color="Color.Info" Size="Size.Large">
                            Preparing: @GetOrderCountByStatus(OrderStatus.Preparing)
                        </MudChip>
                        <MudChip T="string" Color="Color.Success" Size="Size.Large">
                            Ready: @GetOrderCountByStatus(OrderStatus.Ready)
                        </MudChip>
                    </MudChipSet>
                </MudItem>
                <MudItem xs="3" Class="text-right">
                    <MudText Typo="Typo.h5">@DateTime.Now.ToString("HH:mm:ss")</MudText>
                    <MudText Typo="Typo.body2">@DateTime.Now.ToString("ddd, MMM dd")</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </div>
    
    <!-- Filter Bar -->
    <div class="kitchen-filters">
        <MudPaper Elevation="1" Class="pa-2">
            <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">
                <MudButton OnClick="@(() => SetFilter(null))"
                          Variant="@(_selectedFilter == null ? Variant.Filled : Variant.Outlined)">
                    All Orders
                </MudButton>
                <MudButton OnClick="@(() => SetFilter(OrderStatus.Pending))"
                          Variant="@(_selectedFilter == OrderStatus.Pending ? Variant.Filled : Variant.Outlined)">
                    Pending
                </MudButton>
                <MudButton OnClick="@(() => SetFilter(OrderStatus.Preparing))"
                          Variant="@(_selectedFilter == OrderStatus.Preparing ? Variant.Filled : Variant.Outlined)">
                    Preparing
                </MudButton>
                <MudButton OnClick="@(() => SetFilter(OrderStatus.Ready))"
                          Variant="@(_selectedFilter == OrderStatus.Ready ? Variant.Filled : Variant.Outlined)">
                    Ready
                </MudButton>
            </MudButtonGroup>
            
            <MudSpacer />
            
            <!-- Connection Status -->
            @if (KitchenState.Value.IsConnected)
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.Wifi" Color="Color.Success" Size="Size.Medium">
                    Connected
                </MudChip>
            }
            else
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.WifiOff" Color="Color.Error" Size="Size.Medium">
                    Disconnected
                </MudChip>
            }
        </MudPaper>
    </div>
    
    <!-- Main Content Area - Order Cards -->
    <div class="kitchen-content">
        @Body
    </div>
    
    <!-- Settings Button -->
    <div class="kitchen-settings">
        <MudIconButton Icon="@Icons.Material.Filled.Settings" 
                     Color="Color.Default" 
                     Size="Size.Large"
                     Href="/kitchen/settings"
                     Title="Settings" />
    </div>
</div>

<style>
    .kitchen-layout {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
        background-color: #f5f5f5;
    }
    
    .kitchen-header {
        flex-shrink: 0;
    }
    
    .kitchen-filters {
        flex-shrink: 0;
        margin-top: 8px;
    }
    
    .kitchen-content {
        flex: 1;
        overflow: auto;
        padding: 16px;
        /* Grid layout for order cards */
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
        align-content: start;
    }
    
    .kitchen-settings {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 1000;
    }
    
    /* Large, readable text for kitchen staff */
    .kitchen-layout .mud-typography-h4 {
        font-weight: 600;
    }
    
    .kitchen-layout .mud-chip {
        font-weight: 600;
    }
</style>

@code {
    private OrderStatus? _selectedFilter = null;
    
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4682B4",        // SteelBlue
            Secondary = "#FFA500",      // Orange
            Success = "#4CAF50",        // Green
            Error = "#DC143C",          // Crimson
            Warning = "#FFD700",        // Gold
            Info = "#1976D2"            // Blue
        }
    };
    
    private int GetOrderCountByStatus(OrderStatus status)
    {
        return KitchenState.Value.ActiveOrders
            .Count(o => o.Status == status);
    }
    
    private void SetFilter(OrderStatus? status)
    {
        _selectedFilter = status;
        // TODO: Dispatch filter action to Fluxor
        Console.WriteLine($"Filter set to: {status}");
    }
}
