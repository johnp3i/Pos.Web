@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Class="pos-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6">Kennedy's Cafe POS</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body1">@DateTime.Now.ToString("ddd, MMM dd yyyy")</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-4">@context.User.Identity?.Name</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" Href="/logout" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigation</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <AuthorizeView Roles="Admin,Manager,Cashier">
                <MudNavLink Href="/cashier" Icon="@Icons.Material.Filled.PointOfSale" IconColor="Color.Primary">
                    Cashier
                </MudNavLink>
            </AuthorizeView>
            
            <AuthorizeView Roles="Admin,Manager,Waiter">
                <MudNavLink Href="/waiter" Icon="@Icons.Material.Filled.TableRestaurant" IconColor="Color.Primary">
                    Waiter
                </MudNavLink>
            </AuthorizeView>
            
            <AuthorizeView Roles="Admin,Manager,Kitchen">
                <MudNavLink Href="/kitchen" Icon="@Icons.Material.Filled.Restaurant" IconColor="Color.Primary">
                    Kitchen Display
                </MudNavLink>
            </AuthorizeView>
            
            <AuthorizeView Roles="Admin,Manager">
                <MudNavGroup Title="Reports" Icon="@Icons.Material.Filled.Assessment" IconColor="Color.Primary">
                    <MudNavLink Href="/reports/daily-sales" Icon="@Icons.Material.Filled.TrendingUp">
                        Daily Sales
                    </MudNavLink>
                    <MudNavLink Href="/reports/inventory" Icon="@Icons.Material.Filled.Inventory">
                        Inventory
                    </MudNavLink>
                </MudNavGroup>
            </AuthorizeView>
            
            <AuthorizeView Roles="Admin">
                <MudNavGroup Title="Administration" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Primary">
                    <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">
                        Users
                    </MudNavLink>
                    <MudNavLink Href="/admin/config" Icon="@Icons.Material.Filled.Tune">
                        Configuration
                    </MudNavLink>
                    <MudNavLink Href="/admin/monitoring" Icon="@Icons.Material.Filled.Monitor">
                        Monitoring
                    </MudNavLink>
                </MudNavGroup>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>
    
    <MudMainContent Class="pos-layout">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4682B4",        // SteelBlue
            Secondary = "#FFA500",      // Orange
            Success = "#4CAF50",        // Green
            Error = "#DC143C",          // Crimson
            Warning = "#FFD700",        // Gold
            Info = "#1976D2",           // Blue
            AppbarBackground = "#4682B4",
            AppbarText = "#FFFFFF"
        }
    };
    
    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
